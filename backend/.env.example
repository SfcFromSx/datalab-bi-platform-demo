# ==============================================================================
# DataLab Backend Configuration
# ==============================================================================

# ─── LLM Model Selection ───────────────────────────────────────────
# The default model to use for completion requests (e.g. gpt-4o, claude-3-5-sonnet-20241022, gemini/gemini-pro)
LITELLM_MODEL="gpt-4o"

# ─── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"
# Optional: Set this if using a custom proxy or compatible API (like vLLM)
# OPENAI_API_BASE="https://api.openai.com/v1"

# ─── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── Google Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ─── DeepSeek ──────────────────────────────────────────────────────
DEEPSEEK_API_KEY="your-deepseek-api-key"

# ─── Groq ──────────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key"

# ─── HuggingFace ───────────────────────────────────────────────────
HUGGINGFACE_API_KEY="your-hf-api-key"

# ─── Local / Ollama ────────────────────────────────────────────────
# Use "ollama/llama3" in LITELLM_MODEL
OLLAMA_API_BASE="http://localhost:11434"

# ─── Azure OpenAI ──────────────────────────────────────────────────
# AZURE_API_KEY="your-azure-api-key"
# AZURE_API_BASE="https://your-resource.openai.azure.com"
# AZURE_API_VERSION="2024-02-15-preview"

# ==============================================================================
# Database / Application Settings (Defaults below)
# ==============================================================================
# DATABASE_URL="sqlite+aiosqlite:///./data/datalab.db"
# HOST="0.0.0.0"
# PORT=8000
# DEBUG=True
