# ==============================================================================
# DataLab Backend Configuration
# ==============================================================================

# ─── LLM Model Selection ───────────────────────────────────────────
# The default model to use (LiteLLM format).
# For OpenAI-compatible APIs, use "openai/<model-id>" with OPENAI_API_BASE.
LITELLM_MODEL="gpt-4o"

# ─── OpenAI / OpenAI-compatible ────────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"
# Set OPENAI_API_BASE for custom endpoints (Volcengine Ark, vLLM, etc.)
# OPENAI_API_BASE="https://api.openai.com/v1"

# Example: Volcengine Ark (doubao)
# LITELLM_MODEL="openai/ark-code-latest"
# OPENAI_API_KEY="your-ark-api-key"
# OPENAI_API_BASE="https://ark.cn-beijing.volces.com/api/coding/v3"

# ─── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── Google Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ─── DeepSeek ──────────────────────────────────────────────────────
DEEPSEEK_API_KEY="your-deepseek-api-key"

# ─── Groq ──────────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key"

# ─── HuggingFace ───────────────────────────────────────────────────
HUGGINGFACE_API_KEY="your-hf-api-key"

# ─── Local / Ollama ────────────────────────────────────────────────
# Use "ollama_chat/<model>" in LITELLM_MODEL
OLLAMA_API_BASE="http://localhost:11434"

# ─── Azure OpenAI ──────────────────────────────────────────────────
# AZURE_API_KEY="your-azure-api-key"
# AZURE_API_BASE="https://your-resource.openai.azure.com"
# AZURE_API_VERSION="2024-02-15-preview"

# ─── Extra Models (JSON) ──────────────────────────────────────────
# Define additional switchable models as a JSON array.
# Each entry: {"id": "unique-id", "name": "Display Name", "model": "litellm-model-id", "api_key": "...", "api_base": "..."}
# LLM_EXTRA_MODELS='[{"id":"ollama-glm4","name":"GLM-4 (Local)","model":"ollama_chat/glm-4.7-flash:latest","api_base":"http://localhost:11434"}]'

# ==============================================================================
# Database / Application Settings (Defaults below)
# ==============================================================================
# DATABASE_URL="sqlite+aiosqlite:///./data/datalab.db"
# HOST="0.0.0.0"
# PORT=8000
# DEBUG=True
